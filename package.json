{
  "name": "overflow-scroll-fade",
  "description": "Fade effect for scrollable elements with overflow.",
  "version": "0.0.0-development",
  "repository": "github:tobua/overflow-scroll-fade",
  "homepage": "https://tobua.github.io/overflow-scroll-fade",
  "license": "MIT",
  "author": "Matthias Giger",
  "scripts": {
    "check": "biome check --write .",
    "types": "tsc && tsc --project ./test/tsconfig.json"
  },
  "workspaces": [
    "demo"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "typescript": "^7.0.2",
    "zero-configuration": "^1.2.0"
  },
  "peerDependencies": {
    "react": ">= 18",
    "typescript": ">= 6"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "trustedDependencies": [
    "zero-configuration"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./index.tsx",
  "exports": {
    ".": {
      "default": "./index.tsx"
    }
  },
  "files": [
    "*.ts",
    "*.tsx"
  ],
  "keywords": [
    "scroll",
    "overflow",
    "fade",
    "typescript"
  ],
  "configuration": {
    "gitignore": "recommended",
    "vscode": "biome",
    "license": "MIT",
    "typescript": [
      {
        "extends": "plugin",
        "compilerOptions": {
          "jsx": "react-jsx"
        },
        "files": [
          "index.tsx"
        ]
      },
      {
        "extends": "web",
        "folder": "test",
        "compilerOptions": {
          "types": [
            "bun",
            "react"
          ]
        },
        "includes": [
          "*.test.tsx"
        ]
      }
    ],
    "biome": [
      {
        "extends": "recommended",
        "files": {
          "includes": [
            "**/*",
            "!demo/**/*",
            "!test/**/*"
          ]
        }
      },
      {
        "folder": "test",
        "extends": "test",
        "root": false,
        "files": {
          "includes": [
            "*.ts",
            "*.test.tsx"
          ]
        }
      }
    ]
  }
}
